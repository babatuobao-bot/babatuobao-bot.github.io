<div class="header"><div class="header-inner"><h1 onclick="showPage('home')">📚 伤寒论</h1><div class="search-box"><span class="search-icon">🔍</span><input type="text" id="searchInput" placeholder="搜索证候、方剂、症状…" oninput="handleSearch(this.value)"><div class="search-results" id="searchResults"></div></div></div></div>
