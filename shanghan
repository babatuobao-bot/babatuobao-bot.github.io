const DATA = {
meridians:[{name:"太阳",desc:"表证·初期",color:"太阳"},{name:"阳明",desc:"里热·极期",color:"阳明"},{name:"少阳",desc:"半表半里",color:"少阳"},{name:"太阴",desc:"脾虚寒",color:"太阴"},{name:"少阴",desc:"心肾阳衰",color:"少阴"},{name:"厥阴",desc:"寒热错杂",color:"厥阴"}],

syndromes:[
{id:"太阳中风证",meridian:"太阳",formula:"桂枝汤",article:"辨太阳病脉证并治上·第12条",main:["发热（翕翕发热）","汗出","恶风","脉浮缓"],secondary:["鼻鸣","干呕","头痛","项强"],mechanism:"风邪袭表，卫强营弱，营卫不和。",key:"发热、汗出、恶风、脉浮缓",differentiate:[["太阳伤寒证","有汗 vs 无汗"],["温病","表虚 vs 里热"]],variants:[["兼项背强几几","太阳中风兼经输不利证","桂枝加葛根汤"],["兼喘","太阳中风兼喘证","桂枝加厚朴杏子汤"],["发汗太过阳虚","太阳病发汗太过阳虚证","桂枝加附子汤"]],articles:[{text:"太阳中风，阳浮而阴弱，阳浮者热自发，阴弱者汗自出，啬啬恶寒，淅淅恶风，翕翕发热，鼻鸣干呕者，桂枝汤主之。",source:"辨太阳病脉证并治上·第12条"},{text:"太阳病，头痛，发热，汗出，恶风者，桂枝汤主之。",source:"辨太阳病脉证并治上·第13条"}]},
{id:"太阳伤寒证",meridian:"太阳",formula:"麻黄汤",article:"辨太阳病脉证并治上·第3条",main:["恶寒","发热","无汗","脉浮紧"],secondary:["头痛","身痛","腰痛","骨节疼痛","喘","呕逆"],mechanism:"寒邪束表，卫阳被遏，营阴郁滞。",key:"恶寒、发热、无汗、身疼痛、脉浮紧",differentiate:[["太阳中风证","无汗 vs 有汗"],["太阳伤寒兼里热证","无烦躁 vs 有烦躁"]],variants:[["兼项背强几几","太阳伤寒兼经输不利证","葛根汤"],["兼里热烦躁","太阳伤寒兼里热证","大青龙汤"],["兼水饮","外寒内饮证","小青龙汤"]],articles:[{text:"太阳病，或已发热，或未发热，必恶寒，体痛，呕逆，脉阴阳俱紧者，名为伤寒。",source:"辨太阳病脉证并治上·第3条"},{text:"太阳病，头痛发热，身疼腰痛，骨节疼痛，恶风，无汗而喘者，麻黄汤主之。",source:"辨太阳病脉证并治中·第35条"}]},
{id:"太阳蓄水证",meridian:"太阳",formula:"五苓散",article:"辨太阳病脉证并治下·第71条",main:["小便不利","消渴","微热","脉浮"],secondary:["水入则吐","心下痞"],mechanism:"太阳表邪不解，随经入腑，膀胱气化不利，水停下焦。",key:"小便不利 + 烦渴欲饮 + 微热 + 脉浮",differentiate:[["胃中干燥","渴欲饮水，小便正常"]],variants:[],articles:[{text:"太阳病，发汗后，大汗出，胃中干，烦躁不得眠，欲得饮水者，少少与饮之，令胃气和则愈。若脉浮，小便不利，微热消渴者，五苓散主之。",source:"辨太阳病脉证并治下·第71条"},{text:"中风发热，六七日不解而烦，有表里证，渴欲饮水，水入则吐者，名曰水逆，五苓散主之。",source:"辨太阳病脉证并治下·第74条"}]},
{id:"太阳蓄血轻证",meridian:"太阳",formula:"桃核承气汤",article:"辨太阳病脉证并治下·第103条",main:["少腹急结","其人如狂","小便自利"],secondary:["发热","血自下"],mechanism:"太阳表邪化热入里，与瘀血结于下焦，病势较轻。",key:"少腹急结 + 如狂 + 小便自利",differentiate:[["太阳蓄血重证","少腹急结 vs 少腹硬满"],["太阳蓄水证","小便自利 vs 小便不利"]],variants:[],articles:[{text:"太阳病不解，热结膀胱，其人如狂，血自下，下者愈。其外不解者，尚未可攻，当先解其外；外解已，但少腹急结者，乃可攻之，宜桃核承气汤。",source:"辨太阳病脉证并治下·第103条"}]},
{id:"太阳蓄血重证",meridian:"太阳",formula:"抵当汤",article:"辨太阳病脉证并治下·第106条",main:["少腹硬满","其人发狂","小便自利","脉微而沉"],secondary:["身黄","脉沉结"],mechanism:"太阳表邪随经入里，瘀热互结于下焦，病势深重。",key:"少腹硬满 + 发狂 + 小便自利 + 脉沉",differentiate:[["太阳蓄血轻证","少腹硬满 vs 少腹急结"],["太阳蓄水证","小便自利 vs 小便不利"]],variants:[],articles:[{text:"太阳病六七日，表证仍在，脉微而沉，反不结胸，其人发狂者，以热在下焦，少腹当硬满，小便自利者，下血乃愈。所以然者，以太阳随经，瘀热在里故也，抵当汤主之。",source:"辨太阳病脉证并治下·第106条"}]},
{id:"太阳伤寒兼里热证",meridian:"太阳",formula:"大青龙汤",article:"辨太阳病脉证并治中·第38条",main:["发热恶寒","身疼痛","无汗","烦躁","脉浮紧"],secondary:[],mechanism:"风寒束表，阳郁化热，表寒里热。",key:"伤寒表实证 + 烦躁（里热标志）",differentiate:[],variants:[],articles:[{text:"太阳中风，脉浮紧，发热恶寒，身疼痛，不汗出而烦躁者，大青龙汤主之。若脉微弱，汗出恶风者，不可服之。服之则厥逆，筋惕肉瞤，此为逆也。",source:"辨太阳病脉证并治中·第38条"}]},
{id:"外寒内饮证",meridian:"太阳",formula:"小青龙汤",article:"辨太阳病脉证并治中·第40条",main:["恶寒发热","无汗","咳","喘","干呕"],secondary:["渴","下利","噎","小便不利、少腹满"],mechanism:"风寒外束，水饮内停。外寒内饮，相互搏结。",key:"表寒证 + 咳喘 + 心下有水气",differentiate:[],variants:[],articles:[{text:"伤寒表不解，心下有水气，干呕发热而咳，或渴，或利，或噎，或小便不利、少腹满，或喘者，小青龙汤主之。",source:"辨太阳病脉证并治中·第40条"}]},
{id:"大结胸证",meridian:"太阳",formula:"大陷胸汤",article:"辨太阳病脉证并治下·第134条",main:["心下痛","按之石硬","脉沉而紧"],secondary:["短气","躁烦","心中懊憹","膈内拒痛"],mechanism:"表证误下，邪热内陷，与水饮互结于胸膈心下。",key:"心下痛 + 按之石硬 + 脉沉紧",differentiate:[],variants:[],articles:[{text:"伤寒六七日，结胸热实，脉沉而紧，心下痛，按之石硬者，大陷胸汤主之。",source:"辨太阳病脉证并治下·第135条"}]},
{id:"小结胸证",meridian:"太阳",formula:"小陷胸汤",article:"辨太阳病脉证并治下·第138条",main:["正在心下","按之则痛","脉浮滑"],secondary:[],mechanism:"痰热互结于心下，病位局限，病势较轻。",key:"正在心下 + 按之则痛 + 脉浮滑",differentiate:[["大结胸证","按之则痛 vs 不按亦痛"]],variants:[],articles:[{text:"小结胸病，正在心下，按之则痛，脉浮滑者，小陷胸汤主之。",source:"辨太阳病脉证并治下·第138条"}]},
{id:"痞证",meridian:"太阳",formula:"半夏泻心汤",article:"辨太阳病脉证并治下·第149条",main:["心下痞","按之濡"],secondary:["呕","肠鸣","下利"],mechanism:"表证误下，脾胃受损，寒热错杂，气机痞塞。",key:"心下满而不痛（区别于结胸的心下硬痛）",differentiate:[["大结胸证","满而不痛 vs 硬痛拒按"],["小结胸证","满而不痛 vs 按之则痛"]],variants:[],articles:[{text:"但满而不痛者，此为痞，柴胡不中与之，宜半夏泻心汤。",source:"辨太阳病脉证并治下·第149条"}]},
{id:"太阳中风兼经输不利证",meridian:"太阳",formula:"桂枝加葛根汤",article:"辨太阳病脉证并治上·第14条",main:["项背强几几","汗出","恶风"],secondary:[],mechanism:"太阳中风，经气不利，津液不能上濡筋脉。",key:"项背强几几 + 汗出 + 恶风",differentiate:[["太阳伤寒兼经输不利证","有汗 vs 无汗"]],variants:[],articles:[{text:"太阳病，项背强几几，反汗出恶风者，桂枝加葛根汤主之。",source:"辨太阳病脉证并治上·第14条"}]},
{id:"太阳伤寒兼经输不利证",meridian:"太阳",formula:"葛根汤",article:"辨太阳病脉证并治中·第31条",main:["项背强几几","无汗","恶风"],secondary:[],mechanism:"风寒束表，经气不利，津液不布，筋脉失养。",key:"项背强几几 + 无汗 + 恶风",differentiate:[["太阳中风兼经输不利证","无汗 vs 有汗"]],variants:[],articles:[{text:"太阳病，项背强几几，无汗恶风者，葛根汤主之。",source:"辨太阳病脉证并治中·第31条"}]},
{id:"太阳中风兼喘证",meridian:"太阳",formula:"桂枝加厚朴杏子汤",article:"辨太阳病脉证并治上·第18条",main:["太阳中风证主证","喘"],secondary:[],mechanism:"太阳中风，肺气不利。或素有喘疾，复感风邪。",key:"中风证 + 喘",differentiate:[],variants:[],articles:[{text:"喘家，作桂枝汤，加厚朴、杏子佳。",source:"辨太阳病脉证并治上·第18条"}]},
{id:"太阳病发汗太过阳虚证",meridian:"太阳",formula:"桂枝加附子汤",article:"辨太阳病脉证并治上·第20条",main:["汗漏不止","恶风","小便难","四肢微急，难以屈伸"],secondary:[],mechanism:"发汗太过，阳气受损，卫阳不固。",key:"汗漏不止 + 恶风 + 小便难 + 四肢拘急",differentiate:[],variants:[],articles:[{text:"太阳病，发汗，遂漏不止，其人恶风，小便难，四肢微急，难以屈伸者，桂枝加附子汤主之。",source:"辨太阳病脉证并治上·第20条"}]},
{id:"太阳病误下致喘证",meridian:"太阳",formula:"桂枝加厚朴杏子汤",article:"辨太阳病脉证并治中·第43条",main:["微喘","表证未解"],secondary:[],mechanism:"太阳病误用下法，表邪未解，肺气上逆。",key:"下后微喘 + 表未解",differentiate:[],variants:[],articles:[{text:"太阳病，下之微喘者，表未解故也，桂枝加厚朴杏子汤主之。",source:"辨太阳病脉证并治中·第43条"}]},
{id:"协热下利证",meridian:"太阳",formula:"葛根黄芩黄连汤",article:"辨太阳病脉证并治中·第34条",main:["下利不止","脉促","喘而汗出"],secondary:[],mechanism:"表证误下，里热下迫大肠。",key:"误下后下利不止 + 喘而汗出",differentiate:[],variants:[],articles:[{text:"太阳病，桂枝证，医反下之，利遂不止，脉促者，表未解也；喘而汗出者，葛根黄芩黄连汤主之。",source:"辨太阳病脉证并治中·第34条"}]},
{id:"悬饮证",meridian:"太阳",formula:"十枣汤",article:"辨太阳病脉证并治下·第152条",main:["心下痞硬满","引胁下痛","干呕","短气","汗出不恶寒"],secondary:[],mechanism:"水饮停聚胸胁，气机受阻。",key:"心下痞硬满 + 引胁下痛 + 短气",differentiate:[],variants:[],articles:[{text:"太阳中风，下利呕逆，表解者，乃可攻之。其人汗出，发作有时，头痛，心下痞硬满，引胁下痛，干呕短气，汗出不恶寒者，此表解里未和也，十枣汤主之。",source:"辨太阳病脉证并治下·第152条"}]},
{id:"阳明经证",meridian:"阳明",formula:"白虎汤",article:"辨阳明病脉证并治·第219条",main:["大热（蒸蒸发热）","大汗出","大渴","脉洪大"],secondary:["不恶寒，反恶热","身重","面垢"],mechanism:"阳明气分热盛，里热外蒸。",key:"四大症：大热 + 大汗 + 大渴 + 脉洪大",differentiate:[["太阳中风证","不恶寒反恶热"],["太阳伤寒证","大热 vs 发热恶寒"]],variants:[],articles:[{text:"阳明病外证云何？答曰：身热，汗自出，不恶寒，反恶热也。",source:"辨阳明病脉证并治·第182条"},{text:"三阳合病，腹满身重，难以转侧，口不仁面垢，谵语遗尿。若自汗出者，白虎汤主之。",source:"辨阳明病脉证并治·第219条"}]},
{id:"阳明腑实证",meridian:"阳明",formula:"大承气汤",article:"辨阳明病脉证并治·第208条",main:["潮热","谵语","腹满痛","大便硬/燥屎","手足濈然汗出"],secondary:["不恶寒","喘","短气","不能食"],mechanism:"阳明热结，燥屎内结，腑气不通。",key:"潮热 + 谵语 + 腹满痛 + 大便硬",differentiate:[],variants:[],articles:[{text:"阳明病，脉迟，虽汗出不恶寒者，其身必重，短气腹满而喘，有潮热者，此外欲解，可攻里也。手足濈然汗出者，此大便已硬也，大承气汤主之。",source:"辨阳明病脉证并治·第208条"},{text:"阳明病，谵语发潮热，脉滑而疾者，小承气汤主之。",source:"辨阳明病脉证并治·第214条"}]},
{id:"热扰胸膈证",meridian:"阳明",formula:"栀子豉汤",article:"辨阳明病脉证并治·第221条",main:["心中懊憹","舌上胎","烦躁不得眠"],secondary:[],mechanism:"阳明热邪郁于胸膈，热扰心神。",key:"心中懊憹 + 舌上胎",differentiate:[],variants:[],articles:[{text:"阳明病……若下之，则胃中空虚，客气动膈，心中懊憹，舌上胎者，栀子豉汤主之。",source:"辨阳明病脉证并治·第221条"}]},
{id:"少阳病证",meridian:"少阳",formula:"小柴胡汤",article:"辨少阳病脉证并治·第263条",main:["往来寒热","胸胁苦满","嘿嘿不欲饮食","心烦喜呕"],secondary:["口苦","咽干","目眩","胸中烦而不呕","或渴"],mechanism:"邪犯少阳，枢机不利，正邪分争于半表半里。",key:"往来寒热 + 胸胁苦满 + 心烦喜呕 + 口苦咽干目眩",differentiate:[["太阳病","往来寒热 vs 发热恶寒"],["阳明病","往来寒热 vs 但热不寒"]],variants:[],articles:[{text:"少阳之为病，口苦，咽干，目眩也。",source:"辨少阳病脉证并治·第263条"},{text:"伤寒五六日，中风，往来寒热，胸胁苦满，嘿嘿不欲饮食，心烦喜呕，或胸中烦而不呕，或渴，或腹中痛，或胁下痞硬，或心下悸、小便不利，或不渴、身有微热，或咳者，小柴胡汤主之。",source:"辨少阳病脉证并治·第96条"}]},
{id:"太阴病证",meridian:"太阴",formula:"理中丸",article:"辨太阴病脉证并治·第273条",main:["腹满而吐","食不下","下利日益甚","时腹自痛"],secondary:["口不渴","手足温"],mechanism:"脾阳虚弱，寒湿内盛。",key:"腹满而吐 + 食不下 + 下利 + 时腹自痛",differentiate:[["少阴病证","仅脾阳虚 vs 全身阳衰"],["阳明腑实证","虚寒 vs 实热"]],variants:[],articles:[{text:"太阴之为病，腹满而吐，食不下，自利益甚，时腹自痛。若下之，必胸下结硬。",source:"辨太阴病脉证并治·第273条"}]},
{id:"太阴腹痛证",meridian:"太阴",formula:"桂枝加芍药汤",article:"辨太阴病脉证并治·第279条",main:["腹满时痛"],secondary:["大实痛"],mechanism:"太阳误下，邪陷太阴，脾络不和。",key:"腹满时痛（轻）或 大实痛（重）",differentiate:[],variants:[],articles:[{text:"本太阳病，医反下之，因尔腹满时痛者，属太阴也，桂枝加芍药汤主之；大实痛者，桂枝加大黄汤主之。",source:"辨太阴病脉证并治·第279条"}]},
{id:"少阴病证",meridian:"少阴",formula:"四逆汤",article:"辨少阴病脉证并治·第281条",main:["脉微细","但欲寐","四肢厥逆","下利清谷"],secondary:["恶寒踡卧","不渴","小便色白"],mechanism:"心肾阳衰，阴寒内盛。",key:"脉微细 + 但欲寐 + 四肢厥逆",differentiate:[["太阴病证","全身阳衰 vs 仅脾阳虚"]],variants:[],articles:[{text:"少阴之为病，脉微细，但欲寐也。",source:"辨少阴病脉证并治·第281条"}]},
{id:"阴盛格阳证",meridian:"少阴",formula:"通脉四逆汤",article:"辨少阴病脉证并治·第317条",main:["下利清谷","手足厥逆","脉微欲绝","身反不恶寒","面色赤"],secondary:[],mechanism:"阴寒内盛，虚阳被格拒于外。",key:"内真寒 + 外假热（身反不恶寒、面色赤）",differentiate:[["少阴病证","外假热 vs 无热"]],variants:[],articles:[{text:"少阴病，下利清谷，里寒外热，手足厥逆，脉微欲绝，身反不恶寒，其人面色赤，或腹痛，或干呕，或咽痛，或利止脉不出者，通脉四逆汤主之。",source:"辨少阴病脉证并治·第317条"}]},
{id:"少阴兼表证",meridian:"少阴",formula:"麻黄细辛附子汤",article:"辨少阴病脉证并治·第301条",main:["发热","脉沉"],secondary:[],mechanism:"少阴阳虚，复感外邪。",key:"反发热 + 脉沉",differentiate:[],variants:[],articles:[{text:"少阴病，始得之，反发热，脉沉者，麻黄细辛附子汤主之。",source:"辨少阴病脉证并治·第301条"}]},
{id:"少阴阴虚火旺证",meridian:"少阴",formula:"黄连阿胶汤",article:"辨少阴病脉证并治·第303条",main:["心中烦","不得卧"],secondary:[],mechanism:"少阴肾水亏虚，心火独亢，心肾不交。",key:"心烦 + 不得卧",differentiate:[["热扰胸膈证","心烦不得卧 vs 心中懊憹"]],variants:[],articles:[{text:"少阴病，得之二三日以上，心中烦，不得卧，黄连阿胶汤主之。",source:"辨少阴病脉证并治·第303条"}]},
{id:"阳虚水泛证",meridian:"少阴",formula:"真武汤",article:"辨少阴病脉证并治·第316条",main:["腹痛","小便不利","四肢沉重疼痛","自下利"],secondary:["或咳","或呕"],mechanism:"少阴阳虚，水湿泛滥。",key:"腹痛 + 小便不利 + 四肢沉重 + 下利",differentiate:[],variants:[],articles:[{text:"少阴病，二三日不已，至四五日，腹痛，小便不利，四肢沉重疼痛，自下利者，此为有水气。其人或咳，或小便利，或下利，或呕者，真武汤主之。",source:"辨少阴病脉证并治·第316条"}]},
{id:"厥阴病证",meridian:"厥阴",formula:"乌梅丸",article:"辨厥阴病脉证并治·第326条",main:["消渴","气上撞心","心中疼热","饥而不欲食","食则吐蛔"],secondary:[],mechanism:"上热下寒，寒热错杂，厥热胜复。",key:"消渴 + 气上撞心 + 心中疼热 + 饥不欲食",differentiate:[["阳明经证","大渴引饮 vs 消渴+上热下寒"],["太阳蓄水证","大渴+小便不利 vs 消渴+上热下寒"]],variants:[],articles:[{text:"厥阴之为病，消渴，气上撞心，心中疼热，饥而不欲食，食则吐蛔，下之利不止。",source:"辨厥阴病脉证并治·第326条"}]},
{id:"蛔厥证",meridian:"厥阴",formula:"乌梅丸",article:"辨厥阴病脉证并治·第338条",main:["手足厥冷","其人当吐蛔","静而复时烦","得食而呕又烦"],secondary:[],mechanism:"脏寒蛔动，上扰胸膈。",key:"时烦时止 + 吐蛔 + 得食而烦",differentiate:[["藏厥","时烦时止 vs 躁无暂安时"],["热厥证","脏寒蛔动 vs 里热郁闭"]],variants:[],articles:[{text:"蛔厥者，其人当吐蛔。今病者静，而复时烦者，此为藏寒。蛔上入其膈，故烦，须臾复止。得食而呕，又烦者，蛔闻食臭出。其人当自吐蛔。蛔厥者，乌梅丸主之。",source:"辨厥阴病脉证并治·第338条"}]},
{id:"热厥证",meridian:"厥阴",formula:"白虎汤",article:"辨厥阴病脉证并治·第350条",main:["手足厥逆","脉滑","里有热"],secondary:[],mechanism:"热邪内郁，阳气不能外达四肢。",key:"厥逆 + 脉滑（热象）",differentiate:[["寒厥","脉滑 vs 脉微细"],["血虚寒凝证","脉滑 vs 脉细欲绝"]],variants:[],articles:[{text:"伤寒脉滑而厥者，里有热，白虎汤主之。",source:"辨厥阴病脉证并治·第350条"}]},
{id:"血虚寒凝证",meridian:"厥阴",formula:"当归四逆汤",article:"辨厥阴病脉证并治·第351条",main:["手足厥寒","脉细欲绝"],secondary:[],mechanism:"血虚不能温养四肢，寒邪凝滞经脉。",key:"手足厥寒 + 脉细欲绝",differentiate:[["热厥证","脉细欲绝 vs 脉滑"],["少阴病证","脉细欲绝 vs 脉微细"]],variants:[],articles:[{text:"手足厥寒，脉细欲绝者，当归四逆汤主之。",source:"辨厥阴病脉证并治·第351条"}]},
{id:"太阳少阳并病证",meridian:"少阳",formula:"柴胡桂枝汤",article:"辨少阳病脉证并治·第146条",main:["发热微恶寒","支节烦疼","微呕","心下支结"],secondary:[],mechanism:"太阳表证未解，邪入少阳。",key:"表证（发热恶寒）+ 少阳证（微呕、心下支结）",differentiate:[],variants:[],articles:[{text:"伤寒六七日，发热微恶寒，支节烦疼，微呕，心下支结，外证未去者，柴胡桂枝汤主之。",source:"辨少阳病脉证并治·第146条"}]},
{id:"少阳兼水饮证",meridian:"少阳",formula:"柴胡桂枝干姜汤",article:"辨少阳病脉证并治·第147条",main:["胸胁满微结","小便不利","渴而不呕","但头汗出","往来寒热","心烦"],secondary:[],mechanism:"少阳枢机不利，兼水饮内停。",key:"少阳证 + 小便不利 + 渴",differentiate:[],variants:[],articles:[{text:"伤寒五六日，已发汗而复下之，胸胁满微结，小便不利，渴而不呕，但头汗出，往来寒热，心烦者，此为未解也，柴胡桂枝干姜汤主之。",source:"辨少阳病脉证并治·第147条"}]},
