function handleSearch(q){const box=document.getElementById('searchResults');if(!q.trim()){box.classList.remove('active');return}const results=[],ql=q.toLowerCase();DATA.syndromes.forEach(s=>{if(s.id.includes(ql))results.push({type:'证候',id:s.id,meridian:s.meridian})});DATA.formulas.forEach(f=>{if(f.id.includes(ql))results.push({type:'方剂',id:f.id})});DATA.symptoms.forEach(s=>{if(s.id.includes(ql))results.push({type:'症状',id:s.id})});box.innerHTML=results.length?results.slice(0,20).map(r=>{const e=r.meridian?`<span class="tag tag-${r.meridian}" style="font-size:10px;margin-left:auto">${r.meridian}</span>`:'';return`<div class="search-result-item" onclick="openItem('${r.type}','${r.id}')"><span class="type-badge">${r.type}</span>${r.id}${e}</div>`}).join(''):'<div style="padding:12px;text-align:center;color:#999">无匹配结果</div>';box.classList.add('active')}
document.addEventListener('click',e=>{if(!e.target.closest('.search-box'))document.getElementById('searchResults').classList.remove('active')});
function openItem(type,id){document.getElementById('searchResults').classList.remove('active');document.getElementById('searchInput').value='';if(type==='证候'){showPage('syndromes');showSyndromeDetail(id)}else if(type==='方剂'){showPage('formulas');showFormulaDetail(id)}else if(type==='症状'){showPage('symptoms');showSymptomDetail(id)}}

// ===== NAV =====
document.querySelectorAll('.nav-tab').forEach(tab=>{tab.addEventListener('click',()=>showPage(tab.dataset.page))});
function showPage(name){document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));document.getElementById('page-'+name).classList.add('active');document.querySelectorAll('.nav-tab').forEach(t=>{t.classList.toggle('active',t.dataset.page===name)});if(name==='syndromes'){document.getElementById('syndromesList').style.display='';document.getElementById('syndromeDetail').style.display='none'}if(name==='formulas'){document.getElementById('formulasList').style.display='';document.getElementById('formulaDetail').style.display='none'}if(name==='symptoms'){document.getElementById('symptomsList').style.display='';document.getElementById('symptomDetail').style.display='none'}}

// ===== HOME =====
function renderHome(){document.getElementById('meridianCards').innerHTML=DATA.meridians.map(m=>`<div class="meridian-card m-${m.color}" onclick="showSyndromesByMeridian('${m.name}')">${m.name}<small>${m.desc}</small></div>`).join('')}

// ===== SYNDROMES =====
function renderSyndromes(filter){const c=document.getElementById('syndromesList');let ss=filter?DATA.syndromes.filter(s=>s.meridian===filter):DATA.syndromes;let h=`<div class="filters"><span class="filter-chip ${!filter?'active':''}" onclick="renderSyndromes()">全部</span>`;DATA.meridians.forEach(m=>{h+=`<span class="filter-chip ${filter===m.name?'active':''}" onclick="renderSyndromes('${m.name}')">${m.name}</span>`});h+=`</div><div class="cards-grid">`;ss.forEach(s=>{h+=`<div class="card" onclick="showSyndromeDetail('${s.id}')"><h3>${tagHTML(s.meridian)} ${s.id}</h3><p><strong>方剂：</strong>${chip(s.formula,`showFormulaDetail('${s.formula}')`)}</p><p><strong>要点：</strong>${s.key}</p></div>`});h+=`</div>`;c.innerHTML=h}
function showSyndromesByMeridian(m){showPage('syndromes');renderSyndromes(m)}
function showSyndromeDetail(id){showPage('syndromes');document.getElementById('syndromesList').style.display='none';const s=DATA.syndromes.find(x=>x.id===id);if(!s)return;const c=document.getElementById('syndromeDetail');c.style.display='';let h=`<div class="detail-header"><button class="back-btn" onclick="renderSyndromes()">← 返回</button><h2 class="detail-title">${tagHTML(s.meridian)} ${s.id}</h2></div><div class="detail-content">`;h+=`<div class="detail-section"><h4>主证</h4><ul>${s.main.map(x=>`<li>${x}</li>`).join('')}</ul></div>`;if(s.secondary.length)h+=`<div class="detail-section"><h4>兼证</h4><ul>${s.secondary.map(x=>`<li>${x}</li>`).join('')}</ul></div>`;h+=`<div class="detail-section"><h4>病机</h4><p style="font-size:14px">${s.mechanism}</p></div>`;h+=`<div class="detail-section"><h4>辨证要点</h4><div class="original-text">${s.key}</div></div>`;if(s.differentiate.length){h+=`<div class="detail-section"><h4>类证鉴别</h4><div class="table-wrap"><table><tr><th>证候</th><th>鉴别要点</th></tr>`;s.differentiate.forEach(d=>{h+=`<tr><td>${chip(d[0],`showSyndromeDetail('${d[0]}')`)}</td><td>${d[1]}</td></tr>`});h+=`</table></div></div>`}if(s.variants.length){h+=`<div class="detail-section"><h4>兼证变证</h4><div class="table-wrap"><table><tr><th>兼证</th><th>证候</th><th>方剂</th></tr>`;s.variants.forEach(v=>{h+=`<tr><td>${v[0]}</td><td>${chip(v[1],`showSyndromeDetail('${v[1]}')`)}</td><td>${chip(v[2],`showFormulaDetail('${v[2]}')`)}</td></tr>`});h+=`</table></div></div>`}h+=`<div class="detail-section"><h4>原文</h4>`;s.articles.forEach(a=>{h+=`<div class="original-text">${a.text}<div class="source">—— ${a.source}</div></div>`});h+=`</div>`;h+=`<div class="detail-section"><h4>对应方剂</h4><p>${chip(s.formula,`showFormulaDetail('${s.formula}')`)}</p></div></div>`;c.innerHTML=h}

// ===== FORMULAS =====
function renderFormulas(){const c=document.getElementById('formulasList');const cats=[...new Set(DATA.formulas.map(f=>f.category))];let h=`<div class="filters"><span class="filter-chip active" onclick="filterFormulas('')">全部</span>`;cats.forEach(ct=>{h+=`<span class="filter-chip" onclick="filterFormulas('${ct}')">${ct}</span>`});h+=`</div><div class="cards-grid" id="formulaCards">`;DATA.formulas.forEach(f=>{h+=`<div class="card" onclick="showFormulaDetail('${f.id}')" data-cat="${f.category}"><h3>${f.id}${f.alias?` <small style="color:var(--text-secondary)">（${f.alias}）</small>`:''}</h3><p><span class="tag tag-type">${f.category}</span></p><p><strong>主治：</strong>${chip(f.syndrome,`showSyndromeDetail('${f.syndrome}')`)}</p><p><strong>功效：</strong>${f.action}</p></div>`});h+=`</div>`;c.innerHTML=h}
function filterFormulas(cat){document.querySelectorAll('#formulasList .filter-chip').forEach(c=>c.classList.remove('active'));event.target.classList.add('active');document.querySelectorAll('#formulaCards .card').forEach(card=>{card.style.display=(!cat||card.dataset.cat===cat)?'':'none'})}
function showFormulaDetail(id){showPage('formulas');document.getElementById('formulasList').style.display='none';const f=DATA.formulas.find(x=>x.id===id);if(!f)return;const c=document.getElementById('formulaDetail');c.style.display='';let h=`<div class="detail-header"><button class="back-btn" onclick="renderFormulas()">← 返回</button><h2 class="detail-title">${f.id}${f.alias?` <small style="color:var(--text-secondary);font-size:16px">（${f.alias}）</small>`:''}</h2></div><div class="detail-content">`;h+=`<div class="detail-section"><h4>分类</h4><p><span class="tag tag-type">${f.category}</span></p></div>`;h+=`<div class="detail-section"><h4>组成</h4><div class="table-wrap"><table><tr><th>药味</th><th>用量（汉代 → 现代）</th><th>功效</th></tr>`;f.ingredients.forEach(i=>{h+=`<tr><td><strong>${i[0]}</strong></td><td>${i[1]}</td><td>${i[2]}</td></tr>`});h+=`</table></div></div>`;if(f.method)h+=`<div class="detail-section"><h4>煎服法</h4><div class="original-text">${f.method}</div></div>`;h+=`<div class="detail-section"><h4>功效</h4><p style="font-size:14px">${f.action}</p></div>`;if(f.formulaMeaning)h+=`<div class="detail-section"><h4>方义</h4><p style="font-size:14px">${f.formulaMeaning}</p></div>`;if(f.contraindication)h+=`<div class="detail-section"><h4>禁忌</h4><p style="font-size:14px;color:#c44d8b">${f.contraindication}</p></div>`;if(f.variants.length){h+=`<div class="detail-section"><h4>加减变化</h4>`;f.variants.forEach(v=>{h+=`<p style="font-size:14px">${v[0]} → ${chip(v[1],`showFormulaDetail('${v[1]}')`)}</p>`});h+=`</div>`}h+=`<div class="detail-section"><h4>主治证候</h4><p>${chip(f.syndrome,`showSyndromeDetail('${f.syndrome}')`)}</p></div></div>`;c.innerHTML=h}

// ===== SYMPTOMS =====
function renderSymptoms(){const c=document.getElementById('symptomsList');const cats=[...new Set(DATA.symptoms.map(s=>s.category))];let h=`<div class="filters"><span class="filter-chip active" onclick="renderSymptoms()">全部</span>`;cats.forEach(ct=>{h+=`<span class="filter-chip" onclick="filterSymptoms('${ct}')">${ct}</span>`});h+=`</div><div class="table-wrap"><table><tr><th>症状</th><th>类别</th><th>涉及证候</th></tr>`;DATA.symptoms.forEach(s=>{h+=`<tr style="cursor:pointer" onclick="showSymptomDetail('${s.id}')"><td><strong>${s.id}</strong></td><td><span class="tag tag-type">${s.category}</span></td><td>${s.syndromes.map(x=>chip(x.name,`showSyndromeDetail('${x.name}')`)).join('')}</td></tr>`});h+=`</table></div>`;c.innerHTML=h}
function filterSymptoms(cat){document.querySelectorAll('#symptomsList .filter-chip').forEach(c=>c.classList.remove('active'));event.target.classList.add('active');const c=document.getElementById('symptomsList');let ss=cat?DATA.symptoms.filter(s=>s.category===cat):DATA.symptoms;let h=`<div class="filters"><span class="filter-chip ${!cat?'active':''}" onclick="renderSymptoms()">全部</span>`;[...new Set(DATA.symptoms.map(s=>s.category))].forEach(ct=>{h+=`<span class="filter-chip ${cat===ct?'active':''}" onclick="filterSymptoms('${ct}')">${ct}</span>`});h+=`</div><div class="table-wrap"><table><tr><th>症状</th><th>类别</th><th>涉及证候</th></tr>`;ss.forEach(s=>{h+=`<tr style="cursor:pointer" onclick="showSymptomDetail('${s.id}')"><td><strong>${s.id}</strong></td><td><span class="tag tag-type">${s.category}</span></td><td>${s.syndromes.map(x=>chip(x.name,`showSyndromeDetail('${x.name}')`)).join('')}</td></tr>`});h+=`</table></div>`;c.innerHTML=h}
function showSymptomDetail(id){showPage('symptoms');document.getElementById('symptomsList').style.display='none';const s=DATA.symptoms.find(x=>x.id===id);if(!s)return;const c=document.getElementById('symptomDetail');c.style.display='';let h=`<div class="detail-header"><button class="back-btn" onclick="renderSymptoms()">← 返回</button><h2 class="detail-title">${s.id}</h2></div><div class="detail-content"><div class="detail-section"><h4>六经辨证中的表现</h4><div class="table-wrap"><table><tr><th>证候</th><th>特点</th><th>伴随症状</th><th>方剂</th></tr>`;s.syndromes.forEach(x=>{h+=`<tr><td>${chip(x.name,`showSyndromeDetail('${x.name}')`)}</td><td>${x.feature}</td><td>${x.accompany}</td><td>${chip(x.formula,`showFormulaDetail('${x.formula}')`)}</td></tr>`});h+=`</table></div></div></div>`;c.innerHTML=h}

// ===== SYMPTOM CHECKER =====
let selectedSymptoms=new Set();
function renderChecker(){document.getElementById('symptomSelector').innerHTML=DATA.symptoms.map(s=>`<span class="symptom-btn" data-id="${s.id}" onclick="toggleSymptom(this,'${s.id}')">${s.id}</span>`).join('')}
function toggleSymptom(btn,id){if(selectedSymptoms.has(id)){selectedSymptoms.delete(id);btn.classList.remove('selected')}else{selectedSymptoms.add(id);btn.classList.add('selected')}updateChecker()}
function updateChecker(){const r=document.getElementById('checkerResult');if(selectedSymptoms.size===0){r.innerHTML='';return}const matches=DATA.syndromes.map(s=>{const allSymptoms=[...s.main,...s.secondary];const matched=[],missing=[];selectedSymptoms.forEach(sel=>{if(allSymptoms.some(a=>a.includes(sel)))matched.push(sel);else missing.push(sel)});const nameMatch=selectedSymptoms.has(s.id)?[s.id]:[];const totalMatched=matched.length+nameMatch.length;if(totalMatched===0)return null;const totalSymptoms=allSymptoms.length||1;const score=Math.round((totalMatched/Math.max(totalSymptoms,selectedSymptoms.size))*100);return{syndrome:s,matched,missing,score,totalMatched}}).filter(Boolean).sort((a,b)=>b.score-a.score||b.totalMatched-a.totalMatched);if(!matches.length){r.innerHTML='<p style="color:var(--text-secondary);font-size:14px">没有找到匹配的证候，试试其他症状组合？</p>';return}let h=`<h4 style="margin-bottom:12px">匹配结果（${matches.length}个证候）</h4>`;matches.forEach(m=>{h+=`<div class="match-card" onclick="showSyndromeDetail('${m.syndrome.id}')"><h4>${tagHTML(m.syndrome.meridian)} ${m.syndrome.id}</h4><div class="match-bar"><div class="match-bar-fill" style="width:${Math.min(m.score,100)}%"></div></div><div class="match-detail">匹配度 ${Math.min(m.score,100)}% · 方剂：${m.syndrome.formula}</div><div class="match-symptoms"><span class="matched">✓ ${m.matched.join('、')}</span>${m.missing.length?` · <span class="missing">✗ ${m.missing.join('、')}</span>`:''}</div></div>`});r.innerHTML=h}

// ===== INIT =====
renderHome();renderSyndromes();renderFormulas();renderSymptoms();renderChecker();
</script>
</body>
</html>
