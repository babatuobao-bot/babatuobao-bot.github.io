<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>伤寒论知识查询系统</title>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{--bg:#faf8f5;--bg-card:#fff;--text:#2c2c2c;--text-secondary:#666;--border:#e8e4df;--accent:#8b4513;--accent-light:#d4a574;--accent-bg:#fdf5ec;--tag-sun:#e8913a;--tag-yangming:#d94f3d;--tag-shaoyang:#4a9c5d;--tag-taiyin:#3a8fb7;--tag-shaoyin:#7b68a8;--tag-jueyin:#c44d8b;--shadow:0 1px 3px rgba(0,0,0,.06);--shadow-md:0 4px 12px rgba(0,0,0,.08);--radius:8px;--radius-lg:12px}
html{scroll-behavior:smooth}
body{font-family:-apple-system,"Noto Sans SC","PingFang SC","Hiragino Sans GB","Microsoft YaHei",sans-serif;background:var(--bg);color:var(--text);line-height:1.7;min-height:100vh}
.header{background:linear-gradient(135deg,#2c1810,#4a2c1a);color:#fff;padding:0;position:sticky;top:0;z-index:100;box-shadow:0 2px 12px rgba(0,0,0,.15)}
.header-inner{max-width:1200px;margin:0 auto;padding:12px 20px;display:flex;align-items:center;justify-content:space-between;gap:16px}
.header h1{font-size:20px;font-weight:600;white-space:nowrap;cursor:pointer}
.header h1:hover{opacity:.85}
.search-box{flex:1;max-width:420px;position:relative}
.search-box input{width:100%;padding:8px 14px 8px 36px;border:1px solid rgba(255,255,255,.2);border-radius:20px;background:rgba(255,255,255,.1);color:#fff;font-size:14px;outline:none;transition:all .2s}
.search-box input::placeholder{color:rgba(255,255,255,.5)}
.search-box input:focus{background:rgba(255,255,255,.18);border-color:rgba(255,255,255,.35)}
.search-box .search-icon{position:absolute;left:12px;top:50%;transform:translateY(-50%);font-size:14px;opacity:.6}
.search-results{position:absolute;top:calc(100% + 4px);left:0;right:0;background:var(--bg-card);border-radius:var(--radius);box-shadow:var(--shadow-md);max-height:400px;overflow-y:auto;display:none;color:var(--text);font-size:14px}
.search-results.active{display:block}
.search-result-item{padding:10px 14px;cursor:pointer;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:8px}
.search-result-item:last-child{border-bottom:none}
.search-result-item:hover{background:var(--accent-bg)}
.search-result-item .type-badge{font-size:11px;padding:1px 6px;border-radius:3px;background:var(--accent-bg);color:var(--accent);white-space:nowrap}
.nav{background:var(--bg-card);border-bottom:1px solid var(--border);overflow-x:auto}
.nav-inner{max-width:1200px;margin:0 auto;display:flex;padding:0 20px}
.nav-tab{padding:12px 18px;font-size:14px;color:var(--text-secondary);cursor:pointer;white-space:nowrap;border-bottom:2px solid transparent;transition:all .2s;user-select:none}
.nav-tab:hover{color:var(--accent)}
.nav-tab.active{color:var(--accent);border-bottom-color:var(--accent);font-weight:600}
.main{max-width:1200px;margin:0 auto;padding:24px 20px 60px}
.page{display:none}
.page.active{display:block}
.hero{text-align:center;padding:40px 20px}
.hero h2{font-size:28px;color:var(--accent);margin-bottom:8px}
.hero p{color:var(--text-secondary);font-size:15px;margin-bottom:24px}
.hero .quote{font-size:16px;color:var(--accent);font-style:italic;padding:16px 24px;background:var(--accent-bg);border-left:3px solid var(--accent);border-radius:0 var(--radius) var(--radius) 0;display:inline-block;margin-bottom:32px}
.flow-diagram{display:flex;align-items:center;justify-content:center;gap:12px;flex-wrap:wrap;margin-bottom:40px}
.flow-item{padding:10px 20px;background:var(--bg-card);border:1px solid var(--border);border-radius:var(--radius);font-size:14px;font-weight:500;box-shadow:var(--shadow)}
.flow-arrow{font-size:20px;color:var(--accent-light)}
.section-title{font-size:18px;font-weight:600;margin-bottom:16px;padding-bottom:8px;border-bottom:1px solid var(--border)}
.cards-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:16px;margin-bottom:32px}
.card{background:var(--bg-card);border:1px solid var(--border);border-radius:var(--radius-lg);padding:20px;box-shadow:var(--shadow);cursor:pointer;transition:all .2s}
.card:hover{box-shadow:var(--shadow-md);transform:translateY(-2px)}
.card h3{font-size:16px;margin-bottom:8px;display:flex;align-items:center;gap:8px}
.card p{font-size:13px;color:var(--text-secondary);margin-bottom:4px}
.tag{display:inline-block;font-size:11px;padding:2px 8px;border-radius:3px;color:#fff;font-weight:500}
.tag-太阳{background:var(--tag-sun)}.tag-阳明{background:var(--tag-yangming)}.tag-少阳{background:var(--tag-shaoyang)}.tag-太阴{background:var(--tag-taiyin)}.tag-少阴{background:var(--tag-shaoyin)}.tag-厥阴{background:var(--tag-jueyin)}.tag-type{background:var(--accent-bg);color:var(--accent)}
.detail-header{display:flex;align-items:center;gap:12px;margin-bottom:24px}
.back-btn{padding:6px 14px;background:var(--bg-card);border:1px solid var(--border);border-radius:var(--radius);cursor:pointer;font-size:13px;color:var(--text-secondary);transition:all .2s}
.back-btn:hover{border-color:var(--accent);color:var(--accent)}
.detail-title{font-size:24px;font-weight:700}
.detail-content{background:var(--bg-card);border:1px solid var(--border);border-radius:var(--radius-lg);padding:28px;box-shadow:var(--shadow)}
.detail-section{margin-bottom:24px}
.detail-section:last-child{margin-bottom:0}
.detail-section h4{font-size:15px;color:var(--accent);margin-bottom:10px;padding-bottom:6px;border-bottom:1px dashed var(--border)}
.detail-section ul{list-style:none;padding:0}
.detail-section li{padding:4px 0;font-size:14px}
.detail-section li::before{content:"· ";color:var(--accent-light);font-weight:bold}
.original-text{background:var(--accent-bg);border-left:3px solid var(--accent);padding:16px 20px;border-radius:0 var(--radius) var(--radius) 0;font-size:14px;line-height:1.9;margin:8px 0}
.original-text .source{font-size:12px;color:var(--text-secondary);margin-top:8px;font-style:italic}
.table-wrap{overflow-x:auto}
table{width:100%;border-collapse:collapse;font-size:14px}
th,td{padding:10px 14px;text-align:left;border-bottom:1px solid var(--border)}
th{background:var(--accent-bg);font-weight:600;color:var(--accent);font-size:13px}
td{font-size:13px}
tr:hover td{background:var(--accent-bg)}
.link-chip{display:inline-block;padding:3px 10px;margin:2px 4px 2px 0;background:var(--accent-bg);border:1px solid var(--border);border-radius:14px;font-size:12px;color:var(--accent);cursor:pointer;transition:all .2s}
.link-chip:hover{background:var(--accent);color:#fff}
.meridian-cards{display:grid;grid-template-columns:repeat(auto-fill,minmax(160px,1fr));gap:12px;margin-bottom:24px}
.meridian-card{text-align:center;padding:20px 12px;border-radius:var(--radius-lg);cursor:pointer;transition:all .2s;color:#fff;font-weight:600;font-size:16px}
.meridian-card:hover{transform:scale(1.03);box-shadow:var(--shadow-md)}
.meridian-card small{display:block;font-size:12px;font-weight:400;opacity:.85;margin-top:4px}
.m-太阳{background:linear-gradient(135deg,#e8913a,#f0a858)}.m-阳明{background:linear-gradient(135deg,#d94f3d,#e87060)}.m-少阳{background:linear-gradient(135deg,#4a9c5d,#65b878)}.m-太阴{background:linear-gradient(135deg,#3a8fb7,#58a8cc)}.m-少阴{background:linear-gradient(135deg,#7b68a8,#9685be)}.m-厥阴{background:linear-gradient(135deg,#c44d8b,#d86ea8)}
@media(max-width:640px){.header-inner{flex-wrap:wrap}.search-box{order:3;max-width:100%;flex-basis:100%}.hero h2{font-size:22px}.cards-grid{grid-template-columns:1fr}.detail-content{padding:16px}.flow-diagram{flex-direction:column}.flow-arrow{transform:rotate(90deg)}.meridian-cards{grid-template-columns:repeat(2,1fr)}}
.breadcrumb{font-size:13px;color:var(--text-secondary);margin-bottom:16px}
.breadcrumb span{cursor:pointer;color:var(--accent)}
.breadcrumb span:hover{text-decoration:underline}
.filters{display:flex;flex-wrap:wrap;gap:8px;margin-bottom:20px}
.filter-chip{padding:6px 14px;border:1px solid var(--border);border-radius:16px;font-size:13px;cursor:pointer;background:var(--bg-card);color:var(--text-secondary);transition:all .2s}
.filter-chip:hover,.filter-chip.active{border-color:var(--accent);color:var(--accent);background:var(--accent-bg)}
.checker{background:var(--bg-card);border:1px solid var(--border);border-radius:var(--radius-lg);padding:24px;box-shadow:var(--shadow)}
.checker h3{margin-bottom:12px;font-size:16px}
.symptom-selector{display:flex;flex-wrap:wrap;gap:8px;margin-bottom:16px}
.symptom-btn{padding:6px 14px;border:1px solid var(--border);border-radius:16px;font-size:13px;cursor:pointer;background:var(--bg);transition:all .2s}
.symptom-btn:hover{border-color:var(--accent)}
.symptom-btn.selected{background:var(--accent);color:#fff;border-color:var(--accent)}
.checker-result{margin-top:16px}
.match-card{padding:14px;border:1px solid var(--border);border-radius:var(--radius);margin-bottom:10px;background:var(--bg);cursor:pointer}
.match-card:hover{border-color:var(--accent)}
.match-card h4{font-size:15px;margin-bottom:6px}
.match-bar{height:4px;background:var(--border);border-radius:2px;margin:8px 0;overflow:hidden}
.match-bar-fill{height:100%;border-radius:2px;background:var(--accent);transition:width .3s}
.match-detail{font-size:12px;color:var(--text-secondary)}
.match-symptoms{font-size:12px;margin-top:6px}
.match-symptoms .matched{color:var(--accent);font-weight:600}
.match-symptoms .missing{color:var(--text-secondary);text-decoration:line-through}
.g{font-size:12px;color:#999}
</style>
</head>
